# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.

# GIPHY API key — get one free at https://developers.giphy.com
GIPHY_API_KEY=your_giphy_api_key_here

# Backend URL
# Android emulator: use 10.0.2.2 (maps to host's localhost)
# Physical device on same WiFi: use your machine's local IP, e.g. 192.168.1.x:8000
# Production: your deployed server URL
HUSH_API_URL=http://10.0.2.2:8000

# Google OAuth2 Web Client ID (from Firebase Console → Project Settings → Web client)
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com


